{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role and auth details",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": ["string", "null"] },
        "profileImage": { "type": "string" },
        "role": { "type": "string", "enum": ["citizen", "admin", "moderator"] },
        "isEmailVerified": { "type": "boolean" },
        "isPhoneVerified": { "type": "boolean" },
        "isSuspended": { "type": "boolean" },
        "fcmTokens": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" },
        "lastLogin": { "type": "number" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "address": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" }
          }
        },
        "stats": {
          "type": "object",
          "properties": {
            "complaintsSubmitted": { "type": "number" },
            "complaintsResolved": { "type": "number" },
            "trustScore": { "type": "number" }
          }
        },
        "settings": {
          "type": "object",
          "properties": {
            "notificationsEnabled": { "type": "boolean" },
            "biometricEnabled": { "type": "boolean" },
            "twoFactorEnabled": { "type": "boolean" }
          }
        }
      },
      "required": ["fullName", "email", "role", "isEmailVerified", "isSuspended", "fcmTokens"]
    },
    "Session": {
      "title": "Session",
      "description": "User login session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "deviceInfo": { "type": "string" },
        "ipAddress": { "type": "string" },
        "loginTime": { "type": "number" },
        "lastActive": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["userId", "deviceInfo", "ipAddress", "loginTime", "lastActive", "isActive"]
    },
    "Complaint": {
      "title": "Complaint",
      "description": "A civic issue report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "resolved", "escalated"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "number" },
        "upvotes": { "type": "number" },
        "department": { "type": "string" },
        "assignedOfficer": { "type": "string" },
        "slaDeadline": { "type": "number" }
      },
      "required": ["userId", "title", "category", "status", "location"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "User login sessions"
    },
    "/complaints/{complaintId}": {
      "schema": "Complaint",
      "description": "Civic issue complaints"
    }
  }
}
